# Local/default environment template for Docker or shell exports.
# Copy to .env (or export the variables in your runtime) and adjust the values.

SPRING_PROFILES_ACTIVE=dev
PORT=8092

# MySQL connection (Google Cloud SQL in production)
DATABASE_URL=localhost
DATABASE_PORT=3306
DATABASE_NAME=daop-entreprenly
DATABASE_USER=root
DATABASE_PASSWORD=password

# Required in the prod profile
JWT_SECRET=replace-with-a-strong-random-secret
