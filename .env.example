# Local/default environment template for Docker or shell exports.
# Copy to .env (or export the variables in your runtime) and adjust the values.

SPRING_PROFILES_ACTIVE=dev
PORT=8092

# PostgreSQL connection for local development (dev profile, host:port)
DATABASE_URL=localhost
DATABASE_PORT=5432
DATABASE_NAME=daop-entreprenly
DATABASE_USER=postgres
DATABASE_PASSWORD=password

# Required in the prod profile
JWT_SECRET=replace-with-a-strong-random-secret

# Production (prod profile) connects to Cloud SQL through the Java socket factory.
# Instead of DATABASE_URL/DATABASE_PORT, set the instance connection name:
# CLOUD_SQL_CONNECTION_NAME=project:region:instance
